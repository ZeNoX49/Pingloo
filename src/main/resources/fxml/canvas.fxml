<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dbeditor.controller.CanvasController">
   <top>
      <ToolBar fx:id="toolBar" BorderPane.alignment="CENTER">
        <items>
            <MenuButton mnemonicParsing="false" style="-fx-background-color: #3b82f6;" text="📂 Ouvrir" textFill="WHITE">
              <items>
                  <Menu fx:id="mOpenFile" mnemonicParsing="false" text="Fichier" />
                  <Menu fx:id="mOpenDb" mnemonicParsing="false" text="BDD" />
              </items>
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </MenuButton>
            <MenuButton mnemonicParsing="false" style="-fx-background-color: #10b981;" text="💾 Sauvegarder" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
               <items>
                  <Menu fx:id="mSaveFile" mnemonicParsing="false" text="Fichier" />
                  <Menu fx:id="mSaveDb" mnemonicParsing="false" text="BDD" />
               </items>
            </MenuButton>
            <MenuButton fx:id="mbDatabase" mnemonicParsing="false" style="-fx-background-color: #cc0033;" text="🛠 Database" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </MenuButton>
            <MenuButton mnemonicParsing="false" style="-fx-background-color: #dd9e3f;" text="🎨 Theme" textFill="WHITE">
               <items>
                  <MenuItem fx:id="miLightTheme" mnemonicParsing="false" text="Light Theme" />
                  <MenuItem fx:id="miDarkTheme" mnemonicParsing="false" text="Dark Theme" />
                  <Menu mnemonicParsing="false" text="Perso Theme">
                    <items>
                      <MenuItem fx:id="miPersoTheme" mnemonicParsing="false" text="use" />
                        <MenuItem mnemonicParsing="false" onAction="#openPersoThemeParameter">
                           <graphic>
                              <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../img/parametre.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </MenuItem>
                    </items>
                  </Menu>
               </items>
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </MenuButton>
            <Separator orientation="VERTICAL" />
            <Region fx:id="spacer1" />
            <Separator orientation="VERTICAL" />
            <TextField fx:id="tfDbName" />
            <Separator orientation="VERTICAL" />
            <Region fx:id="spacer2" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="appNameLabel" text="Visual Database Editor">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
        </items>
      </ToolBar>
   </top>
   <center>
      <StackPane fx:id="spPane" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
